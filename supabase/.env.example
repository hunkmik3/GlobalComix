# Supabase Edge Function env.
# Never prefix secrets with VITE_; VITE_* values are bundled into the browser.
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"
APP_SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Use either R2_ENDPOINT or R2_ACCOUNT_ID. R2_ENDPOINT wins when both are set.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ENDPOINT="https://your-cloudflare-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET="your-r2-bucket"
